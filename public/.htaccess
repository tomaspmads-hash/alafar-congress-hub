# SPA estática — Congreso ALAFAR 2026
# Fallback para el routing client-side de TanStack Router:
# cualquier ruta que NO sea un archivo o directorio real se sirve con index.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache largo para assets con hash en el nombre (inmutables).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|eot|png|jpe?g|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # El HTML siempre fresco para tomar los nuevos hashes en cada deploy.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Compresión (si el hosting lo permite).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
